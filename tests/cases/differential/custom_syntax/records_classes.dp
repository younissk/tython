record Animal {
    name: str
}

class Fish is Animal {
    init var name: str
    pub var age: int = 0

    setup {
        this.age = this.age + 1
    }

    pub func speak() -> none {
        print(this.name)
    }
}

const FISH = Fish(name: "Nemo")
const ANIMAL = Animal {
    name: "Nemo"
}
print(FISH.age)
